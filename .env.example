# Admin app under test (Playwright baseURL). Override when pointing at staging or preview.
PLAYWRIGHT_BASE_URL=https://isoko-admin-portal.vercel.app

# OAuth / API origin used after "Continue with Admin OAuth" (authorize page host).
OAUTH_BASE_URL=https://api.dev.isoko.africa

# Optional: aliases supported by tests (ADMIN_* preferred; ISOKO_* for parity with landing-page suites).
ADMIN_SIGNIN_EMAIL=
ADMIN_SIGNIN_PASSWORD=
ISOKO_EMAIL=
ISOKO_PASSWORD=
